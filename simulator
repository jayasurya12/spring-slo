#!/bin/bash

# Continuous SLO Simulator
# Usage: ./simulator <interval> <total_count> <error_count> [error_status_codes]
# Examples:
#   ./simulator 10s 1000 50
#   ./simulator 10s 1000 50 500,501,404
#   ./simulator 10s 1000 50 500,503,429,404,408

set -e

BASE_URL="${BASE_URL:-http://localhost:8080}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Validate arguments
if [ $# -lt 3 ]; then
    echo "Usage: $0 <interval> <total_count> <error_count> [error_status_codes]"
    echo ""
    echo "Arguments:"
    echo "  interval:           Time between batches (e.g., 10s, 1m)"
    echo "  total_count:        Total requests per batch"
    echo "  error_count:        Number of error requests per batch"
    echo "  error_status_codes: Comma-separated list of HTTP error codes to cycle through"
    echo "                      Default: 500"
    echo "                      Example: 500,501,404"
    echo "                      Example: 500,503,429,404,408,401,403"
    echo ""
    echo "Supported error codes: 400,401,402,403,404,405,406,407,408,409,"
    echo "                       410,411,412,413,414,415,416,417,418,422,"
    echo "                       423,424,425,426,428,429,431,451,"
    echo "                       500,501,502,503,504,505,506,507,508,510,511"
    echo ""
    echo "Examples:"
    echo "  $0 10s 1000 50"
    echo "  $0 10s 1000 50 500,501,404"
    exit 1
fi

INTERVAL_STR="$1"
TOTAL_COUNT="$2"
ERROR_COUNT="$3"
ERROR_CODES_RAW="${4:-500}"

# Parse interval (convert to seconds)
parse_interval() {
    local interval="$1"
    local num=$(echo "$interval" | sed 's/[^0-9]//g')
    local unit=$(echo "$interval" | sed 's/[0-9]//g')

    case "$unit" in
        ms)
            echo "0.$((num / 1000))" | sed 's/\.\.*/./' ;;
        s)
            echo "$num" ;;
        m)
            echo "$((num * 60))" ;;
        h)
            echo "$((num * 3600))" ;;
        *)
            echo "$interval" | sed 's/[^0-9.]//g' ;;
    esac
}

INTERVAL=$(parse_interval "$INTERVAL_STR")

# Parse error status codes into an array
IFS=',' read -ra ERROR_CODES <<< "$ERROR_CODES_RAW"
NUM_ERROR_CODES=${#ERROR_CODES[@]}

# Validate numeric inputs
if ! echo "$TOTAL_COUNT" | grep -qE '^[0-9]+$' || ! echo "$ERROR_COUNT" | grep -qE '^[0-9]+$'; then
    echo "Error: total_count and error_count must be numbers"
    exit 1
fi

if [ "$ERROR_COUNT" -gt "$TOTAL_COUNT" ]; then
    echo "Error: error_count cannot be greater than total_count"
    exit 1
fi

SUCCESS_COUNT=$((TOTAL_COUNT - ERROR_COUNT))

# Build display string for status codes
CODES_DISPLAY=$(IFS=', '; echo "${ERROR_CODES[*]}")

echo -e "${BLUE}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
echo -e "${BLUE}в•‘         Continuous SLO Simulator                        в•‘${NC}"
echo -e "${BLUE}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
echo ""
echo "Configuration:"
echo "  Base URL:          $BASE_URL"
echo "  Interval:          ${INTERVAL}s"
echo "  Total/Batch:       $TOTAL_COUNT"
echo "  Success:           $SUCCESS_COUNT"
echo "  Errors:            $ERROR_COUNT"
echo "  Error Status Codes: [$CODES_DISPLAY]"
echo ""
echo -e "${YELLOW}Press Ctrl+C to stop${NC}"
echo ""

# Check if server is running
echo -n "Checking server health... "
if ! curl -sf "${BASE_URL}/health" > /dev/null 2>&1; then
    echo -e "${RED}FAILED${NC}"
    echo "Server not responding at $BASE_URL"
    exit 1
fi
echo -e "${GREEN}OK${NC}"
echo ""

# Counters
BATCH=0
TOTAL_SENT=0
TOTAL_SUCCESS=0
TOTAL_ERRORS=0

# Per-code error counters (associative array)
declare -A CODE_COUNTERS
for code in "${ERROR_CODES[@]}"; do
    CODE_COUNTERS[$code]=0
done

# Send single request
send_request() {
    local endpoint="$1"
    local method="${2:-GET}"
    local response

    response=$(curl -s -o /dev/null -w "%{http_code}" \
        -X "$method" \
        "${BASE_URL}${endpoint}" 2>/dev/null || echo "000")

    echo "$response"
}

# Pick a status code from the array using round-robin
ROUND_ROBIN_INDEX=0
pick_error_code() {
    local code="${ERROR_CODES[$ROUND_ROBIN_INDEX]}"
    ROUND_ROBIN_INDEX=$(( (ROUND_ROBIN_INDEX + 1) % NUM_ERROR_CODES ))
    echo "$code"
}

# Run one batch
run_batch() {
    local batch_num=$1
    local success_count=0
    local error_count=0
    local failed_count=0

    BATCH=$((batch_num + 1))

    # Send success requests
    for ((i=0; i<SUCCESS_COUNT; i++)); do
        response=$(send_request "/success/200")
        TOTAL_SENT=$((TOTAL_SENT + 1))

        if [ "$response" -eq 200 ]; then
            success_count=$((success_count + 1))
            TOTAL_SUCCESS=$((TOTAL_SUCCESS + 1))
        else
            failed_count=$((failed_count + 1))
        fi
    done

    # Send error requests using round-robin status codes
    for ((i=0; i<ERROR_COUNT; i++)); do
        local target_code
        target_code=$(pick_error_code)
        response=$(send_request "/error/status/${target_code}")
        TOTAL_SENT=$((TOTAL_SENT + 1))

        if [ "$response" -eq "$target_code" ]; then
            error_count=$((error_count + 1))
            TOTAL_ERRORS=$((TOTAL_ERRORS + 1))
            CODE_COUNTERS[$target_code]=$((CODE_COUNTERS[$target_code] + 1))
        else
            failed_count=$((failed_count + 1))
        fi
    done

    # Print batch summary
    local timestamp
    timestamp=$(date '+%H:%M:%S')
    printf "[%s] Batch %d: " "$timestamp" "$BATCH"
    printf "${GREEN}%d success${NC}, " "$success_count"
    printf "${RED}%d errors${NC}, " "$error_count"
    printf "${YELLOW}%d failed${NC}" "$failed_count"
    printf " | Total: %d sent\n" "$TOTAL_SENT"
}

# Cleanup on exit
cleanup() {
    echo ""
    echo ""
    echo "в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
    echo "  Final Statistics"
    echo "в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
    echo "  Total Batches:    $BATCH"
    echo "  Total Requests:   $TOTAL_SENT"
    echo "  Successful:       $TOTAL_SUCCESS"
    echo "  Total Errors:     $TOTAL_ERRORS"
    echo "  Failed (other):   $((TOTAL_SENT - TOTAL_SUCCESS - TOTAL_ERRORS))"
    echo ""
    echo "  Error Breakdown by Status Code:"
    for code in "${ERROR_CODES[@]}"; do
        printf "    HTTP %-5s: %d\n" "$code" "${CODE_COUNTERS[$code]}"
    done
    echo ""

    # Fetch final metrics
    echo "Server metrics:"
    curl -sf "${BASE_URL}/metrics" 2>/dev/null || echo "  Could not fetch metrics"
    echo ""
    echo "Stopped."
    exit 0
}

trap cleanup INT TERM

# Main loop
echo "Starting simulation loop..."
echo ""

while true; do
    run_batch "$BATCH"
    sleep "$INTERVAL"
done
